generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  userType  UserType @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id     String  @id @default(uuid())
  name   String
  banner String?
}

enum UserType {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  DELIVERYMAN
}

model Product {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?

  price       Float
  discount    Float?   @default(0)

  stock       Int      @default(0)
  sku         String?  @unique

  images      String[] // multiple image URLs

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}
